{
  "manifest_version": 3,
  "name": "YouTube Rec Sort",
  "description": "Sorts YouTube Home recommendations by view count and hides non-video blocks.",
  "version": "0.2.1",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
